<Window x:Class="TaskPlanning.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskPlanning.App.ViewModels"
        mc:Ignorable="d"
        Title="Авторизация" Height="360" Width="380" 
        WindowStartupLocation="CenterScreen" Background="#F8F9FA">
    <Border Background="White" CornerRadius="8" Margin="25" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="25,20,25,20">
            <StackPanel>
                <TextBlock Text="Авторизация" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="#212529"
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20"/>
                <StackPanel>
                    <TextBlock Text="Логин" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                             Height="32" 
                             VerticalContentAlignment="Center"
                             Padding="5,0,5,0"
                             Margin="0,0,0,12"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Пароль" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,15"/>
                    <PasswordBox x:Name="PbPassword" 
                                 Height="32" 
                                 VerticalContentAlignment="Center"
                                 Padding="5,0,5,0"
                                 Margin="0,0,0,20"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                            Content="Вход" 
                            Command="{Binding LoginCommand}" 
                            CommandParameter="{Binding ElementName=PbPassword}"
                            Height="38" 
                            Background="#0D6EFD" 
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="2" 
                            Content="Регистрация" 
                            Command="{Binding RegisterCommand}" 
                            CommandParameter="{Binding ElementName=PbPassword}"
                            Height="38" 
                            Background="#6C757D" 
                            Foreground="White"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <TextBlock Text="{Binding Message}" 
                           Foreground="{Binding MessageColor}" 
                           FontSize="13"
                           HorizontalAlignment="Center" 
                           TextAlignment="Center"
                           Margin="0,15,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
