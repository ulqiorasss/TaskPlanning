<Window x:Class="TaskPlanning.App.AddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskPlanning.App"
        mc:Ignorable="d"
       Title="Задачи" Height="500" Width="440" 
        WindowStartupLocation="CenterOwner" Background="#F8F9FA">
    <Border Background="White" CornerRadius="8" Margin="20" BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Окно задачи" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#212529"
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Название задачи" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,4"/>
                        <TextBox x:Name="TitleTextBox"
                                 Height="32" 
                                 VerticalContentAlignment="Center"
                                 Padding="5,0,5,0"
                                 Background="White" BorderBrush="Black"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Описание задачи" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,4"/>
                        <TextBox x:Name="DescriptionTextBox"
                                 Height="80" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True"
                                 Padding="5"
                                 Background="White" BorderBrush="Black"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Срок выполнения" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,4"/>
                            <DatePicker x:Name="DueDatePicker" 
                                        Height="32" 
                                        VerticalContentAlignment="Center"
                                        Background="White" BorderBrush="Black"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Тег (Категория)" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,4"/>
                            <TextBox x:Name="TagTextBox" 
                                     Height="32" 
                                     VerticalContentAlignment="Center"
                                     Padding="5,0,5,0"
                                     Background="White" BorderBrush="Black"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
            <Button Grid.Row="1" 
                    Content="Сохранить" 
                    x:Name="SaveButton"
                    Click="SaveButton_Click" 
                    Height="38" 
                    Background="#0D6EFD" 
                    Foreground="White"
                    FontWeight="SemiBold"
                    FontSize="14"
                    Cursor="Hand"
                    IsDefault="True"
                    Margin="0,15,0,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>
</Window>
