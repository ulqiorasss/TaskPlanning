<Window x:Class="TaskPlanning.App.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskPlanning.App"
        mc:Ignorable="d"
        Title="Регистрация нового пользователя" Height="380" Width="360" 
        WindowStartupLocation="CenterOwner" Background="#F8F9FA">

    <Border Background="White" CornerRadius="8" Margin="20" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid Margin="20">
            <StackPanel>
                <TextBlock Text="Новый аккаунт" FontSize="20" FontWeight="Bold" Foreground="#212529" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <!-- Поле: Имя -->
                <TextBlock Text="Имя пользователя" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtName" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                <!-- Поле: Логин -->
                <TextBlock Text="Логин" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtLogin" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,12"/>

                <!-- Поле: Пароль -->
                <TextBlock Text="Пароль" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PbPassword" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

                <!-- Кнопка подтверждения -->
                <Button Content="Создать аккаунт" 
                        Click="BtnRegister_Click"
                        Height="36" Background="#6C757D" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
