<Window x:Class="HabitTracker.App.PersonSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitTracker.App"
        mc:Ignorable="d"
        Title="Выбор пользователя" Height="450" Width="400">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выбор пользователя" Margin="0,0,0,15" HorizontalAlignment="Center"/>
        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding People}" 
                 SelectedItem="{Binding SelectedPerson}"
                 DisplayMemberPath="Name"
                 Margin="0,0,0,15">
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox Width="260" Padding="5"  Text="{Binding NewPersonName, UpdateSourceTrigger=PropertyChanged}" Tag="Имя нового пользователя"/>
            <Button Content="Создать" Width="100" Margin="5,0,0,0" Command="{Binding AddPersonCommand}"/>
        </StackPanel>
        <Button Grid.Row="3" Content="Войти в аккаунт" Height="40" Command="{Binding LoginCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Grid>
</Window>


