<Window x:Class="TaskPlanning.App.TaskInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskPlanning.App"
        mc:Ignorable="d"
        Title="Информация о задаче" Height="420" Width="400" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Детали задачи" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="Название:" Foreground="Gray" FontSize="12"/>
            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" TextWrapping="Wrap"/>
            <TextBlock Text="Описание:" Foreground="Gray" FontSize="12"/>
            <TextBlock Text="{Binding Description}" Margin="0,0,0,10" TextWrapping="Wrap"/>
            <TextBlock Text="Срок выполнения:" Foreground="Gray" FontSize="12"/>
            <TextBlock Text="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Margin="0,0,0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="1" x:Name="AdminPanel" Margin="0,15,0,0">
            <TextBlock Text="Поделиться задачей" FontSize="14" FontWeight="Bold" Margin="0,10,0,8"/>

            <TextBlock Text="Выберите исполнителя:" FontSize="12" Foreground="Gray" Margin="0,0,0,4"/>
            <ComboBox x:Name="CbUsers" 
                      DisplayMemberPath="Name" 
                      Height="28" 
                      Margin="0,0,0,12" 
                      Background="White" 
                      BorderBrush="Black"/>

            <Button Content="Отправить пользователю" 
                    Click="BtnShare_Click"
                    Height="32" 
                    Background="#0D6EFD" 
                    Foreground="White" 
                    FontWeight="SemiBold" 
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
