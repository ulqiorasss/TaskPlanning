<Window x:Class="HabitTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabitTracker.App"
        mc:Ignorable="d"
        Title="Главное окно" Height="500" Width="700" 
        WindowStartupLocation="CenterScreen" Background="#F8F9FA">

    <Window.Resources>
        <!-- Конвертер для скрытия админских кнопок при необходимости -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Общий стиль для кнопок управления -->
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Добро пожаловать," FontSize="12" Foreground="#6C757D" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding CurrentPerson.Name, FallbackValue='Пользователь 1'}" 
                           FontSize="22" FontWeight="Bold" Foreground="#212529" Margin="0,2,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" 
                    Content="Добавить задачу" 
                    Command="{Binding AddTaskCommand}" 
                    Height="36" 
                    Background="#0D6EFD" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Cursor="Hand"
                    VerticalAlignment="Center">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Теги:" FontSize="13" FontWeight="SemiBold" Foreground="#495057" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <ComboBox Grid.Row="0" Grid.Column="1" 
                          ItemsSource="{Binding AvailableTags}" 
                          SelectedItem="{Binding SelectedTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"    
                          DisplayMemberPath="Name"
                          Height="30" Margin="0,0,0,10" Background="White" BorderBrush="#CED4DA" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Период:" FontSize="13" FontWeight="SemiBold" Foreground="#495057" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" 
                          ItemsSource="{Binding Periods}" 
                          SelectedItem="{Binding SelectedPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Height="30" Background="White" BorderBrush="#CED4DA" VerticalContentAlignment="Center"/>
            </Grid>

            <StackPanel Grid.Column="1" Margin="25,0,25,0" VerticalAlignment="Center">
                <TextBlock Text="Ваш прогресс выполнения" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,6" HorizontalAlignment="Left"/>
                <ProgressBar Height="14" Minimum="0" Maximum="100" 
                             Value="{Binding Progress, Mode=OneWay}" 
                             Background="#E9ECEF" BorderThickness="0" Foreground="#198754">
                    <ProgressBar.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="7"/>
                        </Style>
                    </ProgressBar.Resources>
                </ProgressBar>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <Button Content="Детали задачи" 
                        Style="{StaticResource ControlButtonStyle}"
                        Margin="0,0,0,8"
                        Command="{Binding OpenDetailsCommand}" 
                        CommandParameter="{Binding SelectedTask}"/>
                <Button Content="Редактировать" 
                        Style="{StaticResource ControlButtonStyle}"
                        Margin="0,0,0,8"
                        Command="{Binding EditTaskCommand}" 
                        CommandParameter="{Binding SelectedTask}" />
                <Button Content="Удалить задачу" 
                        Style="{StaticResource ControlButtonStyle}"
                        Foreground="#DC3545"
                        Command="{Binding DeleteTaskCommand}" 
                        CommandParameter="{Binding SelectedTask}"/>
            </StackPanel>
        </Grid>
        <Border Grid.Row="2" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <ListBox ItemsSource="{Binding Tasks}" 
                     SelectedItem="{Binding SelectedTask, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch" Padding="10">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#F1F3F5" BorderThickness="0,0,0,1" Padding="5,8,5,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="{Binding Title, FallbackValue='Название задачи'}" 
                                           FontSize="14"
                                           Foreground="#212529"
                                           VerticalAlignment="Center" 
                                           Margin="5,0,15,0"
                                           TextWrapping="Wrap"/>

                                <CheckBox Grid.Column="1" 
                                          VerticalAlignment="Center" 
                                          Margin="0,0,5,0"
                                          IsChecked="{Binding IsCompleted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Command="{Binding DataContext.ToggleTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Window>

